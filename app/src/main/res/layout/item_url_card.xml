<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        app:cardUseCompatPadding="true"
        app:strokeWidth="0dp"
        app:strokeColor="@android:color/transparent">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

        <!-- 访问地址标题 -->
        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="访问地址"
                android:textSize="10sp"
                android:textColor="#616161"
                android:layout_marginBottom="4dp"/>

        <!-- 本机URL行 -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

            <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="本机"
                        android:textSize="8sp"
                        android:textColor="#757575"/>

                <TextView
                        android:id="@+id/localUrlValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="http://127.0.0.1:8090"
                        android:textSize="11sp"
                        android:textColor="#212121"/>

            </LinearLayout>

            <ImageButton
                    android:id="@+id/copyLocalUrlButton"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_copy"
                    android:background="@android:color/transparent"
                    android:contentDescription="复制本机URL"
                    android:scaleType="centerInside"
                    android:padding="4dp"/>

        </LinearLayout>

        <!-- 分隔线 -->
        <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginBottom="4dp"/>

        <!-- 网络URL行 -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

            <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="网络"
                        android:textSize="8sp"
                        android:textColor="#757575"/>

                <TextView
                        android:id="@+id/networkUrlValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="未启动"
                        android:textSize="11sp"
                        android:textColor="#212121"/>

            </LinearLayout>

            <ImageButton
                    android:id="@+id/copyNetworkUrlButton"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_copy"
                    android:background="@android:color/transparent"
                    android:contentDescription="复制网络URL"
                    android:scaleType="centerInside"
                    android:padding="4dp"/>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>

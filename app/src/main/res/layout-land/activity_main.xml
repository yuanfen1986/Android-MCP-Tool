<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp"
        tools:context=".MainActivity">

    <!-- 页面顶部标题 -->
    <TextView
            android:id="@+id/dashboardTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="MCP工具"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#212121"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 服务器控制按钮 -->
    <LinearLayout
            android:id="@+id/serverControls"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/dashboardTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

        <Button
                android:id="@+id/startServerButton"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:text="启动服务器"
                android:textSize="10sp"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF"
                android:minHeight="28dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"/>

        <Button
                android:id="@+id/stopServerButton"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="停止服务器"
                android:textSize="10sp"
                android:backgroundTint="#F44336"
                android:textColor="#FFFFFF"
                android:minHeight="28dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"/>

    </LinearLayout>

    <!-- 下拉刷新 + 指标列表区域 -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefresh"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/serverControls"
            app:layout_constraintBottom_toTopOf="@id/logHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="6dp">

        <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerDashboard"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="8dp"
                android:scrollbars="vertical"/>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- 日志输出区域，方便查看工具运行状态和刷新记录 -->
    <LinearLayout
            android:id="@+id/logHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/swipeRefresh"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

        <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="日志输出"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#212121"/>

        <ImageButton
                android:id="@+id/clearLogButton"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_delete"
                android:background="@android:color/transparent"
                android:contentDescription="清理日志"
                android:scaleType="centerInside"
                android:padding="4dp"
                android:layout_marginStart="6dp"/>

    </LinearLayout>

    <ScrollView
            android:id="@+id/logScrollView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="#F5F5F5"
            android:scrollbars="vertical"
            android:overScrollMode="always"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/logHeader"
            app:layout_constraintHeight_percent="0.4">

        <TextView
                android:id="@+id/logOutput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:text="日志输出区域\n（运行日志将在这里显示）"
                android:textColor="#424242"
                android:textSize="10sp"
                android:gravity="start"
                android:textIsSelectable="true"
                android:focusable="true"
                android:longClickable="true"/>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
